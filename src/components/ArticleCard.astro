---
interface Props {
  title: string;
  excerpt: string;
  category: string;
  date: string;
  slug: string;
  featured?: boolean;
}

const { title, excerpt, category, date, slug, featured = false } = Astro.props;

// Tentukan warna pill berdasarkan kategori
let pillClass = "pill-primary";
if (category.toLowerCase() === "pengumuman") pillClass = "pill-gold";
else if (category.toLowerCase() === "agenda") pillClass = "bg-blue-50 text-blue-700 border-blue-100";
---

<a href={`/informasi/${slug}`} class="card-hover flex flex-col h-full group overflow-hidden">
  <!-- Image Placeholder -->
  <div class="h-48 w-full bg-gradient-to-br from-primary-100 to-primary-50 flex items-center justify-center relative overflow-hidden">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-200 group-hover:scale-110 transition-transform duration-500">
      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
    </svg>
    
    <div class="absolute top-3 left-3 flex gap-2">
      <span class={`pill ${pillClass} shadow-sm backdrop-blur-sm bg-opacity-90`}>{category}</span>
      {featured && (
        <span class="pill bg-red-50 text-red-600 border-red-100 shadow-sm backdrop-blur-sm bg-opacity-90">Penting</span>
      )}
    </div>
  </div>
  
  <!-- Content -->
  <div class="p-5 flex flex-col flex-grow">
    <h3 class="text-lg font-bold text-ink mb-2 line-clamp-2 group-hover:text-primary-700 transition-colors">
      {title}
    </h3>
    
    <p class="text-sm text-muted line-clamp-3 mb-4 flex-grow">
      {excerpt}
    </p>
    
    <div class="flex items-center text-xs text-muted font-medium mt-auto pt-4 border-t border-line/50">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1.5"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
      {date}
    </div>
  </div>
</a>

---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { name: 'Beranda', href: `${base}/` },
  { name: 'Profil Desa', href: `${base}/profil` },
  { name: 'Informasi', href: `${base}/informasi` },
  { name: 'Pertanian', href: `${base}/pertanian` },
  { name: 'Layanan', href: `${base}/layanan` },
];
---

<footer class="bg-primary-900 text-white py-12 md:py-16">
  <div class="container-page">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center text-primary-700 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m8 3 4 8 5-5 5 15H2L8 3z"/>
            </svg>
          </div>
          <div class="flex flex-col leading-tight">
            <span class="font-display font-bold text-white text-sm tracking-wide">PORTAL RANCAJAYA</span>
          </div>
        </div>
        <p class="text-primary-100 text-sm mt-2">
          Desa yang maju, mandiri, dan sejahtera berbasis pertanian dan kearifan lokal.
        </p>
        <div class="flex items-center gap-3 mt-2">
          <a href="#" class="w-8 h-8 rounded-full bg-primary-800 flex items-center justify-center hover:bg-gold-500 hover:text-primary-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" class="w-8 h-8 rounded-full bg-primary-800 flex items-center justify-center hover:bg-gold-500 hover:text-primary-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </a>
          <a href="#" class="w-8 h-8 rounded-full bg-primary-800 flex items-center justify-center hover:bg-gold-500 hover:text-primary-900 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          </a>
        </div>
      </div>

      <!-- Navigasi -->
      <div>
        <h3 class="font-display font-semibold text-lg mb-4 text-gold-500">Navigasi</h3>
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-primary-100 hover:text-white hover:underline transition-all">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kontak -->
      <div>
        <h3 class="font-display font-semibold text-lg mb-4 text-gold-500">Kontak</h3>
        <ul class="flex flex-col gap-4 text-sm text-primary-100">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Jl. Raya Rancajaya No. 01, Desa Rancajaya, Kec. Patokbeusi, Kab. Subang, Jawa Barat</span>
          </li>
          <li class="mt-2">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31688.082987151247!2d107.63665799999999!3d-6.3813955!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e696ce3210168cb%3A0xc3f2e1a3b3dfa3c!2sRancajaya%2C%20Kec.%20Patokbeusi%2C%20Kabupaten%20Subang%2C%20Jawa%20Barat!5e0!3m2!1sid!2sid!4v1700000000000!5m2!1sid!2sid" width="100%" height="120" style="border:0; border-radius: 0.5rem;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <span>desa.rancajaya@gmail.com</span>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>(0260) 1234567</span>
          </li>
        </ul>
      </div>

      <!-- Jam Operasional -->
      <div>
        <h3 class="font-display font-semibold text-lg mb-4 text-gold-500">Jam Operasional</h3>
        <ul class="flex flex-col gap-3 text-sm text-primary-100">
          <li class="flex justify-between">
            <span>Senin - Jumat</span>
            <span>08:00 - 16:00</span>
          </li>
          <li class="flex justify-between">
            <span>Sabtu</span>
            <span>08:00 - 12:00</span>
          </li>
          <li class="flex justify-between text-gold-300">
            <span>Minggu / Libur</span>
            <span>Tutup</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-primary-700/50 my-8"></div>

    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-primary-200">
      <p>&copy; {currentYear} Portal Rancajaya. Hak Cipta Dilindungi.</p>
      <p>Dikelola oleh Tim KKN 2026.</p>
    </div>
  </div>
</footer>

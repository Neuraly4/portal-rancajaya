---
interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
  showCTA?: boolean;
  ctaText?: string;
  ctaHref?: string;
}

const { 
  title, 
  subtitle, 
  eyebrow, 
  showCTA = false, 
  ctaText = "Pelajari Lebih Lanjut", 
  ctaHref = "#" 
} = Astro.props;
---

<div class="relative bg-gradient-to-br from-primary-800 to-primary-600 text-white overflow-hidden isolate">
  <!-- Decorative pattern -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="leaf" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M20 5c5 0 10 5 10 10s-5 10-10 10S10 20 10 15 15 5 20 5z" fill="currentColor" fill-opacity="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#leaf)" />
    </svg>
  </div>

  <div class="container-page relative z-10 py-16 md:py-24 flex flex-col items-center text-center justify-center min-h-[240px] md:min-h-[320px]">
    {eyebrow && (
      <span class="inline-block mb-3 px-3 py-1 rounded-pill bg-gold-500/20 text-gold-300 text-xs font-bold uppercase tracking-widest animate-fade-in-up">
        {eyebrow}
      </span>
    )}
    
    <h1 class="font-display text-3xl md:text-5xl font-bold mb-4 max-w-3xl leading-tight animate-fade-in-up stagger-1">
      {title}
    </h1>
    
    {subtitle && (
      <p class="text-base md:text-lg text-primary-50 max-w-2xl animate-fade-in-up stagger-2">
        {subtitle}
      </p>
    )}
    
    {showCTA && (
      <div class="mt-8 animate-fade-in-up stagger-3">
        <a href={ctaHref} class="btn-gold !px-8 !py-3.5 !text-base shadow-lg shadow-gold-500/20">
          {ctaText}
        </a>
      </div>
    )}
  </div>
</div>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const beritaEntries = await getCollection('berita');
  return beritaEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Format date
const dateFormatted = new Intl.DateTimeFormat('id-ID', {
  dateStyle: 'long',
}).format(entry.data.date);

let pillClass = "pill-primary";
if (entry.data.category.toLowerCase() === "pengumuman") pillClass = "pill-gold";
else if (entry.data.category.toLowerCase() === "agenda") pillClass = "bg-blue-50 text-blue-700 border-blue-100";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${entry.data.title} — Desa Rancajaya`} description={entry.data.excerpt}>
  
  <article class="bg-paper pb-16">
    <!-- Header/Hero -->
    <header class="bg-gradient-to-br from-primary-800 to-primary-600 text-white pt-24 pb-20 px-4 md:px-8 relative isolate">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="leaf" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M20 5c5 0 10 5 10 10s-5 10-10 10S10 20 10 15 15 5 20 5z" fill="currentColor" fill-opacity="0.5"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#leaf)" />
        </svg>
      </div>

      <div class="max-w-4xl mx-auto relative z-10 animate-fade-in-up">
        <a href={`${base}/informasi`} class="inline-flex items-center gap-2 text-primary-100 hover:text-white mb-8 transition-colors text-sm font-semibold">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Kembali ke Informasi
        </a>
        
        <div class="flex gap-2 mb-4">
          <span class="inline-flex items-center px-3 py-1 rounded-pill bg-gold-500/20 text-gold-300 text-xs font-bold uppercase tracking-widest">
            {entry.data.category}
          </span>
          {entry.data.featured && (
            <span class="inline-flex items-center px-3 py-1 rounded-pill bg-red-500/20 text-red-100 text-xs font-bold uppercase tracking-widest border border-red-500/30">
              Penting
            </span>
          )}
        </div>
        
        <h1 class="font-display text-3xl md:text-5xl font-bold mb-6 leading-tight">
          {entry.data.title}
        </h1>
        
        <div class="flex items-center gap-4 text-sm text-primary-100">
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>{entry.data.author}</span>
          </div>
          <span class="opacity-50">•</span>
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <span>{dateFormatted}</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Content -->
    <div class="max-w-4xl mx-auto px-4 md:px-8 -mt-10 relative z-20">
      <div class="card p-6 md:p-10 min-h-[500px] animate-fade-in-up stagger-1">
        {entry.data.thumbnail && (
          <div class="w-full h-64 md:h-96 rounded-xl overflow-hidden mb-8">
            <img src={entry.data.thumbnail} alt={entry.data.title} class="w-full h-full object-cover" />
          </div>
        )}
        
        <div class="prose prose-lg prose-emerald max-w-none">
          <Content />
        </div>
      </div>
    </div>
  </article>
</Layout>

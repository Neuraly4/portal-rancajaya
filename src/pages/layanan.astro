---
import { getEntry, getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const umumData = await getEntry('pengaturan', 'umum');
const common = umumData?.data || {};

const layananData = await getEntry('halaman', 'layanan');
const layanan = layananData?.data || { administrasi: [], faq: [] };

const daruratData = await getCollection('layanan-darurat');
---

<Layout title={`Layanan Publik - ${common.nama_desa || 'Desa Rancajaya'}`}>
  <Hero 
    eyebrow="Layanan" 
    title="Layanan Desa" 
    subtitle={`Informasi layanan administrasi, pengaduan, dan kontak penting di lingkungan ${common.nama_desa || 'Desa Rancajaya'}`}
  />

  <section class="section">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Kolom Kiri: Kontak & Peta -->
        <div class="lg:col-span-4 space-y-6">
          <div class="card p-6">
            <h3 class="font-display font-bold text-lg text-ink mb-4">Kontak Desa</h3>
            <ul class="flex flex-col gap-4 text-sm">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600 shrink-0 mt-0.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                <span class="text-muted leading-relaxed">{common.alamat_kantor || 'Jl. Raya Rancajaya No. 01, Desa Rancajaya, Kec. Patokbeusi, Kab. Subang, Jawa Barat'}</span>
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600 shrink-0"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <span class="text-muted leading-relaxed">{common.email || 'desa.rancajaya@gmail.com'}</span>
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600 shrink-0"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span class="text-muted leading-relaxed">{common.telepon || '(0260) 1234567'}</span>
              </li>
            </ul>
            
            <div class="mt-6 pt-6 border-t border-line">
              <h4 class="font-semibold text-sm text-ink mb-3">Jam Pelayanan</h4>
              <ul class="flex flex-col gap-2 text-sm text-muted">
                <li class="flex justify-between">
                  <span>Senin - Jumat</span>
                  <span class="font-semibold text-ink">08:00 - 16:00</span>
                </li>
                <li class="flex justify-between">
                  <span>Sabtu</span>
                  <span class="font-semibold text-ink">08:00 - 12:00</span>
                </li>
                <li class="flex justify-between text-red-600">
                  <span>Minggu / Libur</span>
                  <span class="font-semibold">Tutup</span>
                </li>
              </ul>
            </div>
          </div>

          <div class="card overflow-hidden h-64 bg-paper flex items-center justify-center border border-line">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31688.082987151247!2d107.63665799999999!3d-6.3813955!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e696ce3210168cb%3A0xc3f2e1a3b3dfa3c!2sRancajaya%2C%20Kec.%20Patokbeusi%2C%20Kabupaten%20Subang%2C%20Jawa%20Barat!5e0!3m2!1sid!2sid!4v1700000000000!5m2!1sid!2sid" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>

        <!-- Kolom Kanan: Formulir & FAQ -->
        <div class="lg:col-span-8 space-y-10">
          <!-- Surat Pengantar -->
          <div>
            <h2 class="font-display font-bold text-2xl text-ink mb-4">Layanan Administrasi Daring</h2>
            <p class="text-sm text-muted mb-6">Ajukan permohonan surat pengantar dan administrasi lainnya melalui formulir online untuk mempercepat pelayanan sebelum datang ke balai desa.</p>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {layanan.administrasi && layanan.administrasi.map((item) => (
                <a href={item.link} class="card-hover p-5 flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg bg-primary-50 flex items-center justify-center text-primary-700 shrink-0">
                    {item.ikon ? (
                      <span set:html={item.ikon}></span>
                    ) : (
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>
                    )}
                  </div>
                  <div>
                    <h3 class="font-bold text-ink text-sm mb-1">{item.nama}</h3>
                    <p class="text-xs text-muted">Layanan administrasi online</p>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Layanan Darurat -->
          <div>
            <h2 class="font-display font-bold text-2xl text-ink mb-4">Layanan Darurat & Penting</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {daruratData.map((darurat) => (
                <div class={`card p-4 flex items-center justify-between border-l-4 ${darurat.data.jenis === 'Kesehatan' ? 'border-l-red-500' : darurat.data.jenis === 'Keamanan' ? 'border-l-blue-500' : 'border-l-gold-500'}`}>
                  <div class="flex items-center gap-3">
                    <div class={`w-8 h-8 rounded-full flex items-center justify-center shrink-0 ${darurat.data.jenis === 'Kesehatan' ? 'bg-red-50 text-red-500' : darurat.data.jenis === 'Keamanan' ? 'bg-blue-50 text-blue-500' : 'bg-gold-50 text-gold-500'}`}>
                      {darurat.data.jenis === 'Kesehatan' ? (
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                      ) : (
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      )}
                    </div>
                    <span class="font-bold text-ink text-sm">{darurat.data.nama}</span>
                  </div>
                  <span class="text-sm font-semibold text-primary-700">{darurat.data.telepon}</span>
                </div>
              ))}
              {daruratData.length === 0 && (
                <p class="text-sm text-muted">Belum ada kontak darurat yang didaftarkan.</p>
              )}
            </div>
          </div>

          <!-- FAQ -->
          <div>
            <h2 class="font-display font-bold text-2xl text-ink mb-4">Tanya Jawab (FAQ)</h2>
            <div class="space-y-3">
              {(layanan.faq || []).map((faq) => (
                <details class="card group">
                  <summary class="flex items-center justify-between font-semibold p-4 cursor-pointer list-none text-sm text-ink group-open:text-primary-700">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-4 pb-4 text-sm text-muted border-t border-line/50 pt-3">
                    {faq.a}
                  </div>
                </details>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

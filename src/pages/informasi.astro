---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';

const umumData = await getEntry('pengaturan', 'umum');
const common = umumData?.data || {};

// Fetch and sort articles by date (newest first)
const allArticles = await getCollection('berita');
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`Berita & Informasi — ${common.nama_desa || 'Desa Rancajaya'}`} description={`Berita terbaru, agenda, pengumuman, dan informasi penting dari ${common.nama_desa || 'Desa Rancajaya'}, Kecamatan ${common.kecamatan || 'Patokbeusi'}, Kabupaten ${common.kabupaten || 'Subang'}.`}>

  <!-- 1. Hero -->
  <Hero
    eyebrow="Informasi"
    title="Berita & Informasi Desa"
    subtitle={`Kabar terbaru dan informasi penting dari ${common.nama_desa || 'Desa Rancajaya'}`}
  />

  <!-- 2. Search & Filter -->
  <section class="section bg-white border-b border-line">
    <div class="container-page">
      <!-- Search & Sort Controls -->
      <div class="flex flex-col md:flex-row gap-4 mb-6">
        <!-- Search Input -->
        <div class="relative flex-1">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
          </div>
          <input
            id="searchInput"
            type="text"
            placeholder="Cari berita atau informasi..."
            class="w-full pl-11 pr-4 py-3 rounded-lg border border-line bg-white text-ink text-sm placeholder:text-muted/50 focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-all"
          />
        </div>
        
        <!-- Sort Select -->
        <div class="w-full md:w-48">
          <select id="sortSelect" class="w-full px-4 py-3 rounded-lg border border-line bg-white text-ink text-sm focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-400 transition-all">
            <option value="terbaru">Terbaru</option>
            <option value="terlama">Terlama</option>
            <option value="a-z">A - Z</option>
            <option value="z-a">Z - A</option>
          </select>
        </div>
      </div>

      <!-- Filter Pills -->
      <div id="filterPills" class="flex flex-wrap gap-2 justify-center">
        <button data-category="Semua" class="filter-btn px-4 py-1.5 rounded-pill text-sm font-medium border border-primary-200 bg-primary-50 text-primary-700 transition-all">Semua</button>
        <button data-category="Berita" class="filter-btn px-4 py-1.5 rounded-pill text-sm font-medium border border-line text-muted hover:bg-primary-50 hover:text-primary-700 transition-all">Berita</button>
        <button data-category="Agenda" class="filter-btn px-4 py-1.5 rounded-pill text-sm font-medium border border-line text-muted hover:bg-primary-50 hover:text-primary-700 transition-all">Agenda</button>
        <button data-category="Artikel" class="filter-btn px-4 py-1.5 rounded-pill text-sm font-medium border border-line text-muted hover:bg-primary-50 hover:text-primary-700 transition-all">Artikel</button>
        <button data-category="Pengumuman" class="filter-btn px-4 py-1.5 rounded-pill text-sm font-medium border border-line text-muted hover:bg-primary-50 hover:text-primary-700 transition-all">Pengumuman</button>
      </div>
    </div>
  </section>

  <!-- 3. Article Grid -->
  <section class="section bg-paper">
    <div class="container-page">
      <div id="articleGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedArticles.map((article) => {
          const dateFormatted = new Intl.DateTimeFormat('id-ID', {
            dateStyle: 'medium',
          }).format(article.data.date);

          return (
            <div class="article-item" data-title={article.data.title.toLowerCase()} data-category={article.data.category} data-date={article.data.date.valueOf()}>
              <ArticleCard
                title={article.data.title}
                excerpt={article.data.excerpt}
                category={article.data.category}
                date={dateFormatted}
                slug={article.slug}
                featured={article.data.featured}
              />
            </div>
          );
        })}
      </div>
      <div id="noResult" class="hidden text-center py-12 text-muted">
        <p>Tidak ada informasi yang sesuai dengan pencarian Anda.</p>
      </div>

      <!-- 4. Pagination -->
      <nav class="flex justify-center items-center gap-2 mt-10 animate-fade-in-up" aria-label="Pagination">
        <button class="w-10 h-10 rounded-xl bg-primary-700 text-white text-sm font-semibold flex items-center justify-center" aria-current="page">
          1
        </button>
        <button class="w-10 h-10 rounded-xl border border-line text-muted text-sm font-semibold flex items-center justify-center hover:bg-primary-50 hover:text-primary-700 hover:border-primary-200 transition-all">
          2
        </button>
        <button class="w-10 h-10 rounded-xl border border-line text-muted text-sm font-semibold flex items-center justify-center hover:bg-primary-50 hover:text-primary-700 hover:border-primary-200 transition-all">
          3
        </button>
        <button class="w-10 h-10 rounded-xl border border-line text-muted text-sm font-semibold flex items-center justify-center hover:bg-primary-50 hover:text-primary-700 hover:border-primary-200 transition-all" aria-label="Halaman selanjutnya">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6"></path>
          </svg>
        </button>
      </nav>
    </div>
  </section>

</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const searchInput = document.getElementById('searchInput');
    const sortSelect = document.getElementById('sortSelect');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const articleItems = Array.from(document.querySelectorAll('.article-item'));
    const articleGrid = document.getElementById('articleGrid');
    const noResult = document.getElementById('noResult');
    
    let currentFilter = 'Semua';
    
    function filterAndSort() {
      const searchTerm = searchInput.value.toLowerCase();
      const sortVal = sortSelect.value;
      
      let visibleCount = 0;
      
      // Filter
      articleItems.forEach(item => {
        const title = item.getAttribute('data-title');
        const category = item.getAttribute('data-category');
        
        const matchesSearch = title.includes(searchTerm);
        const matchesCategory = currentFilter === 'Semua' || category === currentFilter;
        
        if (matchesSearch && matchesCategory) {
          item.style.display = 'block';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });
      
      // Show/hide no result
      if(visibleCount === 0) {
        noResult.classList.remove('hidden');
      } else {
        noResult.classList.add('hidden');
      }
      
      // Sort
      const visibleItems = articleItems.filter(item => item.style.display !== 'none');
      visibleItems.sort((a, b) => {
        if (sortVal === 'terbaru') {
          return parseInt(b.getAttribute('data-date')) - parseInt(a.getAttribute('data-date'));
        } else if (sortVal === 'terlama') {
          return parseInt(a.getAttribute('data-date')) - parseInt(b.getAttribute('data-date'));
        } else if (sortVal === 'a-z') {
          return a.getAttribute('data-title').localeCompare(b.getAttribute('data-title'));
        } else if (sortVal === 'z-a') {
          return b.getAttribute('data-title').localeCompare(a.getAttribute('data-title'));
        }
      });
      
      // Re-append to DOM in sorted order
      visibleItems.forEach(item => articleGrid.appendChild(item));
    }
    
    // Event Listeners
    searchInput.addEventListener('input', filterAndSort);
    sortSelect.addEventListener('change', filterAndSort);
    
    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        // Reset styles
        filterBtns.forEach(b => {
          b.classList.remove('bg-primary-50', 'text-primary-700', 'border-primary-200');
          b.classList.add('text-muted', 'border-line');
        });
        
        // Set active style
        const target = e.target;
        target.classList.remove('text-muted', 'border-line');
        target.classList.add('bg-primary-50', 'text-primary-700', 'border-primary-200');
        
        currentFilter = target.getAttribute('data-category');
        filterAndSort();
      });
    });
  });
</script>

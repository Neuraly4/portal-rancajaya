---
import { getEntry, getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatCard from '../components/StatCard.astro';

const profilData = await getEntry('halaman', 'profil');
const umumData = await getEntry('pengaturan', 'umum');
const profil = profilData?.data || {};
const common = umumData?.data || {};
const perangkatDesa = await getCollection('perangkat-desa');
const sortedPerangkat = perangkatDesa.sort((a, b) => a.data.urutan - b.data.urutan);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`Profil Desa — ${common.nama_desa || 'Desa Rancajaya'}`} description={`Profil lengkap Desa ${common.nama_desa || 'Rancajaya'} meliputi visi misi, perangkat desa, wilayah administrasi, demografi, dan transparansi APBDes.`}>

  <!-- 1. Hero -->
  <Hero
    eyebrow="Profil"
    title={`Profil Desa ${common.nama_desa || 'Rancajaya'}`}
    subtitle={`Mengenal lebih dekat Desa ${common.nama_desa || 'Rancajaya'}, Kecamatan ${common.kecamatan || 'Patokbeusi'}, Kabupaten ${common.kabupaten || 'Subang'}`}
  />

  <!-- 2. Sambutan Kepala Desa -->
  <section class="section bg-white">
    <div class="container-page">
      <div class="section-header">
        <span class="eyebrow animate-fade-in-up">Sambutan</span>
        <h2 class="section-title animate-fade-in-up stagger-1">Sambutan Kepala Desa</h2>
      </div>
      <div class="card p-6 md:p-8 animate-fade-in-up stagger-2">
        <div class="flex flex-col md:flex-row gap-6 md:gap-8">
          <!-- Photo Placeholder Left -->
          <div class="flex-shrink-0 text-center md:text-left">
            <div class="w-32 h-40 bg-gradient-to-br from-primary-200 via-primary-100 to-primary-50 rounded-xl mx-auto md:mx-0 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-300">
                <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <h3 class="font-bold text-ink mt-3">{profil.nama_kades || '[Nama Kepala Desa]'}</h3>
            <p class="text-sm text-muted">Kepala Desa {common.nama_desa || 'Rancajaya'}</p>
          </div>

          <!-- Quote/Greeting Right -->
          <div class="flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-primary-200 mb-3">
              <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"></path>
              <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"></path>
            </svg>
            {profil.sambutan ? (
              profil.sambutan.split('\n').map((paragraph) => (
                paragraph.trim() && <p class="text-muted leading-relaxed italic mb-4">{paragraph}</p>
              ))
            ) : (
              <p class="text-muted leading-relaxed italic mb-4">"Sambutan belum tersedia."</p>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2b. Quick Navigation -->
  <section class="container-page -mt-4 relative z-20 mb-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <a href="#tentang-desa" class="card-hover p-4 flex flex-col items-center justify-center text-center group bg-white shadow-sm">
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Tentang Desa</span>
      </a>
      <a href="#perangkat-desa" class="card-hover p-4 flex flex-col items-center justify-center text-center group bg-white shadow-sm">
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Perangkat Desa</span>
      </a>
      <a href="#demografi" class="card-hover p-4 flex flex-col items-center justify-center text-center group bg-white shadow-sm">
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Demografi</span>
      </a>
      <a href="#apbdes" class="card-hover p-4 flex flex-col items-center justify-center text-center group bg-white shadow-sm">
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Transparansi APBDes</span>
      </a>
    </div>
  </section>

  <!-- 3. Visi & Misi -->
  <section id="tentang-desa" class="section bg-paper">
    <div class="container-page">
      <div class="section-header">
        <span class="eyebrow">Tentang Desa</span>
        <h2 class="section-title">Visi & Misi</h2>
      </div>

      <!-- Visi -->
      <div class="card p-6 md:p-8 mb-8 text-center border-primary-200 bg-gradient-to-br from-white to-primary-50 animate-fade-in-up stagger-2">
        <span class="eyebrow text-primary-700">Visi</span>
        <p class="text-lg md:text-xl font-display font-bold text-ink mt-3 leading-relaxed">
          "{common.visi || 'Visi belum tersedia'}"
        </p>
      </div>

      <!-- Misi -->
      <div>
        <h3 class="text-center font-display font-bold text-ink mb-6">Misi</h3>
        <div class="grid md:grid-cols-2 gap-4">
          {common.misi && common.misi.length > 0 ? (
            common.misi.map((misiItem, index) => (
              <div class="card p-5 animate-fade-in-up">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-primary-700 text-white flex items-center justify-center font-bold font-display text-sm">{index + 1}</div>
                  <p class="text-muted leading-relaxed">{misiItem}</p>
                </div>
              </div>
            ))
          ) : (
            <p class="text-center text-muted col-span-2">Misi belum tersedia.</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Perangkat Desa -->
  <section class="section bg-white">
    <div class="container-page">
      <div class="section-header">
        <span class="eyebrow animate-fade-in-up">Struktur Organisasi</span>
        <h2 class="section-title animate-fade-in-up stagger-1">Perangkat Desa</h2>
        <p class="section-subtitle animate-fade-in-up stagger-2">Aparatur pemerintahan Desa {common.nama_desa || 'Rancajaya'}</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {sortedPerangkat.length > 0 ? sortedPerangkat.map((pejabat) => (
          <div class="card p-4 text-center animate-fade-in-up">
            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-primary-100 to-primary-50 flex items-center justify-center mx-auto mb-3 overflow-hidden">
              {pejabat.data.foto ? (
                <img src={pejabat.data.foto.startsWith('/') ? base + pejabat.data.foto : pejabat.data.foto} alt={pejabat.data.nama} class="w-full h-full object-cover" />
              ) : (
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-300">
                  <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
              )}
            </div>
            <h4 class="font-semibold text-sm text-ink">{pejabat.data.nama}</h4>
            <p class="text-xs text-muted mt-1">{pejabat.data.jabatan}</p>
          </div>
        )) : (
          <p class="text-muted col-span-4 text-center">Data perangkat desa belum ditambahkan.</p>
        )}
      </div>
    </div>
  </section>

  <!-- 5. Wilayah Administrasi -->
  <section class="section bg-paper">
    <div class="container-page">
      <div class="section-header">
        <span class="eyebrow animate-fade-in-up">Wilayah</span>
        <h2 class="section-title animate-fade-in-up stagger-1">Wilayah Administrasi</h2>
        <p class="section-subtitle animate-fade-in-up stagger-2">Batas wilayah dan pembagian dusun Desa Rancajaya</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Batas Wilayah Table -->
        <div class="card overflow-hidden animate-fade-in-up stagger-1">
          <div class="px-5 py-4 bg-primary-700">
            <h3 class="font-display font-bold text-white text-sm flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              Batas Wilayah
            </h3>
          </div>
          <div class="divide-y divide-line">
            <div class="flex justify-between px-5 py-3">
              <span class="text-sm font-medium text-ink flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500"><path d="m18 15-6-6-6 6"/></svg>
                Utara
              </span>
              <span class="text-sm text-muted">Desa Sukamandijaya</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-sm font-medium text-ink flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500"><path d="m9 18 6-6-6-6"/></svg>
                Timur
              </span>
              <span class="text-sm text-muted">Desa Rancabango</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-sm font-medium text-ink flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500"><path d="m6 9 6 6 6-6"/></svg>
                Selatan
              </span>
              <span class="text-sm text-muted">Desa Rancajaya & Rancabango</span>
            </div>
            <div class="flex justify-between px-5 py-3">
              <span class="text-sm font-medium text-ink flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-500"><path d="m15 18-6-6 6-6"/></svg>
                Barat
              </span>
              <span class="text-sm text-muted">Desa Gempolsari & Rancamulya</span>
            </div>
          </div>
          <div class="px-5 py-3 bg-primary-50 flex justify-between">
            <span class="text-sm font-bold text-primary-700">Luas Wilayah</span>
            <span class="text-sm font-bold text-primary-700">{profil.luas_wilayah || '0'} km²</span>
          </div>
        </div>

        <!-- Dusun List -->
        <div class="card overflow-hidden animate-fade-in-up stagger-2">
          <div class="px-5 py-4 bg-primary-700">
            <h3 class="font-display font-bold text-white text-sm flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
              Pembagian Dusun
            </h3>
          </div>
          <div class="divide-y divide-line">
            {(profil.dusun || []).map((dusun, i) => (
              <div class="flex items-center gap-4 px-5 py-4">
                <div class="w-10 h-10 rounded-xl bg-primary-50 flex items-center justify-center flex-shrink-0">
                  <span class="text-sm font-bold text-primary-700">{i + 1}</span>
                </div>
                <div>
                  <h4 class="font-semibold text-sm text-ink">{dusun}</h4>
                  <p class="text-xs text-muted">Desa {common.nama_desa || 'Rancajaya'}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. Demografi -->
  <section id="demografi" class="section bg-white">
    <div class="container-page">
      <div class="section-header">
        <span class="eyebrow">Data Penduduk</span>
        <h2 class="section-title">Demografi</h2>
        <p class="section-subtitle">Visualisasi data kependudukan Desa {common.nama_desa || 'Rancajaya'}</p>
      </div>

      <!-- Stat Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <StatCard value={`${profil.penduduk_total || '0'}`} label="Total Penduduk (Jiwa)" variant="dark" />
        <StatCard value={`${profil.penduduk_pria || '0'}`} label="Laki-laki (Jiwa)" />
        <StatCard value={`${profil.penduduk_wanita || '0'}`} label="Perempuan (Jiwa)" />
      </div>

      <!-- Charts -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Dusun Pie Chart -->
        <div class="card p-6">
          <h3 class="font-display font-bold text-ink text-sm mb-4">Populasi per Dusun</h3>
          <div class="relative h-64 w-full">
            <canvas id="chartDusun"></canvas>
          </div>
        </div>
        
        <!-- Pendidikan Bar Chart -->
        <div class="card p-6">
          <h3 class="font-display font-bold text-ink text-sm mb-4">Tingkat Pendidikan</h3>
          <div class="relative h-64 w-full">
            <canvas id="chartPendidikan"></canvas>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline define:vars={{ demoDusun: profil.demo_dusun || [], demoPendidikan: profil.demo_pendidikan || [] }}>
    document.addEventListener("DOMContentLoaded", function() {
      // Dusun Chart
      if (demoDusun && demoDusun.length > 0) {
        const ctxDusun = document.getElementById('chartDusun').getContext('2d');
        new Chart(ctxDusun, {
          type: 'pie',
          data: {
            labels: demoDusun.map(d => d.label),
            datasets: [{
              data: demoDusun.map(d => d.value),
              backgroundColor: ['#16a34a', '#eab308', '#2563eb', '#dc2626', '#9333ea'],
            }]
          },
          options: { responsive: true, maintainAspectRatio: false }
        });
      }

      // Pendidikan Chart
      if (demoPendidikan && demoPendidikan.length > 0) {
        const ctxPendidikan = document.getElementById('chartPendidikan').getContext('2d');
        new Chart(ctxPendidikan, {
          type: 'bar',
          data: {
            labels: demoPendidikan.map(d => d.label),
            datasets: [{
              label: 'Jumlah Penduduk',
              data: demoPendidikan.map(d => d.value),
              backgroundColor: '#15803d',
            }]
          },
          options: { responsive: true, maintainAspectRatio: false }
        });
      }
    });
  </script>

  <!-- 7. Transparansi APBDes -->
  <section id="apbdes" class="section bg-paper">
    <div class="container-page">
      <div class="section-header">
        <span class="eyebrow">Keuangan Desa</span>
        <h2 class="section-title">Transparansi APBDes</h2>
        <p class="section-subtitle">Realisasi Anggaran Pendapatan dan Belanja Desa (APBDes)</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <!-- Pendapatan -->
        <div class="card p-6 text-center border-green-200 bg-gradient-to-br from-white to-green-50">
          <p class="text-xs text-muted uppercase tracking-wider font-semibold mb-1">Pendapatan</p>
          <p class="text-3xl font-display font-bold text-green-700">{profil.apbdes?.pendapatan || 'Rp 0'}</p>
        </div>

        <!-- Belanja -->
        <div class="card p-6 text-center border-blue-200 bg-gradient-to-br from-white to-blue-50">
          <p class="text-xs text-muted uppercase tracking-wider font-semibold mb-1">Belanja</p>
          <p class="text-3xl font-display font-bold text-blue-700">{profil.apbdes?.belanja || 'Rp 0'}</p>
        </div>
      </div>

      <!-- Riwayat Tahunan -->
      <div class="card p-6">
        <h3 class="font-display font-bold text-ink text-sm mb-4">Riwayat Anggaran Tahunan</h3>
        <div class="relative h-72 w-full">
          <canvas id="chartApbdes"></canvas>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ apbdesRiwayat: profil.apbdes?.riwayat || [] }}>
    document.addEventListener("DOMContentLoaded", function() {
      if (apbdesRiwayat && apbdesRiwayat.length > 0) {
        const ctxApbdes = document.getElementById('chartApbdes').getContext('2d');
        new Chart(ctxApbdes, {
          type: 'bar',
          data: {
            labels: apbdesRiwayat.map(d => d.tahun),
            datasets: [
              {
                label: 'Pendapatan',
                data: apbdesRiwayat.map(d => d.pendapatan),
                backgroundColor: '#16a34a',
              },
              {
                label: 'Belanja',
                data: apbdesRiwayat.map(d => d.belanja),
                backgroundColor: '#2563eb',
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              y: {
                beginAtZero: true,
                ticks: {
                  callback: function(value) {
                    if (value >= 1000000000) return (value / 1000000000) + ' M';
                    if (value >= 1000000) return (value / 1000000) + ' Jt';
                    return value;
                  }
                }
              }
            }
          }
        });
      }
    });
  </script>
</Layout>

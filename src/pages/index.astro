---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatCard from '../components/StatCard.astro';
import ArticleCard from '../components/ArticleCard.astro';

// Ambil 3 berita terbaru
const allArticles = await getCollection('berita');
const latestArticles = allArticles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Beranda — Website Profil Desa Rancajaya" description="Website resmi Desa Rancajaya, Kecamatan Patokbeusi, Kabupaten Subang.">
  
  <!-- 1. Hero -->
  <Hero
    eyebrow="Selamat Datang di"
    title="Desa Rancajaya"
    subtitle="Desa yang asri dan sejahtera di Kecamatan Patokbeusi, Kabupaten Subang, Jawa Barat. Bersama membangun desa yang lebih maju."
    showCTA={true}
    ctaText="Jelajahi Desa"
    ctaHref={`${base}/profil`}
  />

  <!-- 2. Quick Navigation -->
  <section class="container-page -mt-8 md:-mt-12 relative z-20 mb-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
      <a href={`${base}/profil`} class="card-hover p-6 flex flex-col items-center justify-center text-center group">
        <div class="w-12 h-12 rounded-full bg-primary-50 flex items-center justify-center text-primary-700 mb-3 group-hover:bg-primary-100 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>
        </div>
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Profil Desa</span>
      </a>
      <a href={`${base}/informasi`} class="card-hover p-6 flex flex-col items-center justify-center text-center group">
        <div class="w-12 h-12 rounded-full bg-primary-50 flex items-center justify-center text-primary-700 mb-3 group-hover:bg-primary-100 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
        </div>
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Informasi</span>
      </a>
      <a href={`${base}/pertanian`} class="card-hover p-6 flex flex-col items-center justify-center text-center group">
        <div class="w-12 h-12 rounded-full bg-primary-50 flex items-center justify-center text-primary-700 mb-3 group-hover:bg-primary-100 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"/><path d="M9 7v2"/><path d="M15 7v2"/><path d="M12 2a5 5 0 0 0-5 5v5a5 5 0 0 0 10 0V7a5 5 0 0 0-5-5Z"/></svg>
        </div>
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Pertanian</span>
      </a>
      <a href={`${base}/layanan`} class="card-hover p-6 flex flex-col items-center justify-center text-center group">
        <div class="w-12 h-12 rounded-full bg-primary-50 flex items-center justify-center text-primary-700 mb-3 group-hover:bg-primary-100 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Layanan</span>
      </a>
      <a href={`${base}/layanan#lokasi`} class="card-hover p-6 flex flex-col items-center justify-center text-center group col-span-2 md:col-span-1">
        <div class="w-12 h-12 rounded-full bg-primary-50 flex items-center justify-center text-primary-700 mb-3 group-hover:bg-primary-100 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <span class="font-semibold text-sm text-ink group-hover:text-primary-700">Lokasi Desa</span>
      </a>
    </div>
  </section>

  <!-- 3. Statistik Singkat -->
  <section class="section bg-white border-y border-line">
    <div class="container-page">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <StatCard label="Luas Wilayah" value="8.11 km²">
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"/><path d="M12 2v20"/><path d="M4.93 4.93l14.14 14.14"/><path d="M19.07 4.93L4.93 19.07"/></svg>
        </StatCard>
        <StatCard label="Jumlah Dusun" value="4 Dusun">
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M9 8h1"/><path d="M9 12h1"/><path d="M9 16h1"/><path d="M14 8h1"/><path d="M14 12h1"/><path d="M14 16h1"/><path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"/></svg>
        </StatCard>
        <StatCard label="Jumlah RT" value="25 RT">
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </StatCard>
        <StatCard label="Jumlah Penduduk" value="±8.500">
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </StatCard>
      </div>
    </div>
  </section>

  <!-- 4. Potensi Unggulan -->
  <section class="section bg-paper">
    <div class="container-page">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="eyebrow mb-2">POTENSI UNGGULAN</span>
          <h2 class="section-title mb-4">Lumbung Padi di Utara Subang</h2>
          <p class="section-subtitle mb-6">Sebagian besar wilayah Desa Rancajaya merupakan hamparan sawah yang membentang luas. Sektor pertanian menjadi tulang punggung perekonomian masyarakat kami dengan komoditas unggulan berupa padi sawah yang ditunjang oleh sistem irigasi teknis.</p>
          <a href={`${base}/pertanian`} class="btn-ghost">
            Jelajahi Potensi Pertanian
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
        <div class="relative">
          <div class="absolute inset-0 bg-gold-500 rounded-2xl transform translate-x-3 translate-y-3 opacity-20"></div>
          <div class="h-80 w-full bg-primary-100 rounded-2xl relative z-10 flex items-center justify-center border border-line">
            <span class="text-primary-300 font-medium">Foto Hamparan Sawah</span>
          </div>
        </div>
      </div>
      </div>
    </div>
  </section>

  <!-- 5. Berita Terbaru -->
  <section class="section bg-white border-y border-line">
    <div class="container-page text-center">
      <div class="section-header">
        <span class="eyebrow mb-2">KABAR TERKINI</span>
        <h2 class="section-title">Berita & Informasi Terbaru</h2>
        <p class="section-subtitle mx-auto">Pantau terus perkembangan, pengumuman, dan agenda kegiatan di Desa Rancajaya.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left mb-10">
        {latestArticles.map((article) => {
          const dateFormatted = new Intl.DateTimeFormat('id-ID', {
            dateStyle: 'medium',
          }).format(article.data.date);

          return (
            <ArticleCard
              title={article.data.title}
              excerpt={article.data.excerpt}
              category={article.data.category}
              date={dateFormatted}
              slug={article.slug}
              featured={article.data.featured}
            />
          );
        })}
      </div>
      
      <a href={`${base}/informasi`} class="btn-outline">
        Lihat Semua Berita
      </a>
    </div>
  </section>

  <!-- 6. Peta Lokasi -->
  <section id="peta-lokasi" class="section bg-paper">
    <div class="container-page">
      <div class="section-header">
        <span class="eyebrow animate-fade-in-up">Lokasi</span>
        <h2 class="section-title animate-fade-in-up stagger-1">Peta Desa Rancajaya</h2>
        <p class="section-subtitle animate-fade-in-up stagger-2">Kecamatan Patokbeusi, Kabupaten Subang, Jawa Barat</p>
      </div>
      <div class="bg-primary-50 border-2 border-dashed border-primary-200 rounded-2xl h-64 md:h-96 flex flex-col items-center justify-center animate-fade-in-up stagger-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary-300 mb-3">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <span class="text-primary-500 font-medium text-sm">Google Maps akan ditampilkan di sini</span>
        <span class="text-primary-400 text-xs mt-1">Desa Rancajaya, Kec. Patokbeusi, Kab. Subang</span>
      </div>
    </div>
  </section>

</Layout>
